{
  "name": "besnovatyj/yii2-cms-shop",
  "description": "Модуль интернет-магазина для Yii2 CMS",
  "version": "1.0.0",
  "type": "yii2-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "Besnovatyj",
      "email": "your-email@example.com"
    }
  ],
  "minimum-stability": "stable",
  "extra": {
    "moduleClass": "Besnovatyj\\Shop\\Module",
    "moduleId": "Shop",
    "bootstrap": "Besnovatyj\\Shop\\Bootstrap"
  },
  "keywords": [
    "yii2",
    "shop",
    "cms",
    "ecommerce"
  ],
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    },
    "fxp-asset": {
      "enabled": false
    }
  },
  "require": {
    "php": ">=8.4",
    "yiisoft/yii2": "~2.0.0",
    "yiisoft/yii2-bootstrap5": "~2.0.0",
    "besnovatyj/yii2-cms-meta": "1.0.0",
    "besnovatyj/yii2-cms-images": "1.0.0",
    "besnovatyj/yii2-cms-forms": "1.0.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "Besnovatyj\\Shop\\": "src/"
    }
  }
}
